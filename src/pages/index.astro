---
import MainLayout from '../layouts/MainLayout.astro';
import MovieCard from '../components/MovieCard.astro';

const apiUrl = 'https://v300-tmdb-worker.limingvv789.workers.dev/api/popular';

let movies = [];
let error = null;

try {
  const res = await fetch(apiUrl, {
    headers: { 'Cache-Control': 'no-cache' }   // 开发阶段强制刷新缓存
  });
  
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  
  const data = await res.json();
  movies = data.results || [];
} catch (err) {
  error = '无法加载 TMDB 数据，请检查 Worker 是否正常运行';
  console.error(err);
}
---

<MainLayout title="V300 热门影视">
  <header class="p-6 bg-gradient-to-r from-purple-900 to-indigo-900">
    <h1 class="text-4xl font-bold text-center">V300 影视平台</h1>
  </header>

  <main class="container mx-auto p-6">
    <h2 class="text-2xl mb-6">热门电影</h2>
    
    {error ? (
      <p class="text-red-500 text-center py-12">{error}</p>
    ) : movies.length > 0 ? (
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6">
        {movies.map(movie => (
          <MovieCard movie={movie} />
        ))}
      </div>
    ) : (
      <p class="text-gray-400 col-span-full text-center py-12">加载中...</p>
    )}
  </main>
</MainLayout>