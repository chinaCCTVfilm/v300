---
import MainLayout from '../layouts/MainLayout.astro';
import MovieCard from '../components/MovieCard.astro';

// 临时注释掉真实 fetch，避免超时错误
// const apiUrl = 'https://v300-0nz.pages.dev/api/popular';
// const res = await fetch(apiUrl);
// const data = await res.json();
// const movies = data.results || [];

const movies = [];   // 临时空数组，让页面先渲染出来
---

<MainLayout title="V300 热门影视">
  <header class="p-6 bg-gradient-to-r from-purple-900 to-indigo-900">
    <h1 class="text-4xl font-bold text-center">V300 影视平台</h1>
  </header>

  <main class="container mx-auto p-6">
    <h2 class="text-2xl mb-6">热门电影</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6">
      {movies.length > 0 ? (
        movies.map(movie => <MovieCard movie={movie} />)
      ) : (
        <p class="text-gray-400 col-span-full text-center py-12">正在加载热门电影数据...</p>
      )}
    </div>
  </main>
</MainLayout>