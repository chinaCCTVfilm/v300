---
import MainLayout from '../layouts/MainLayout.astro';
import MovieCard from '../components/MovieCard.astro';

const apiUrl = 'https://your-worker-domain.workers.dev/api/popular';  // Replace with real Worker URL
const res = await fetch(apiUrl);
const data = await res.json();
const movies = data.results || [];
---

<MainLayout title="V300 Popular Movies">
  <header class="p-6 bg-gradient-to-r from-purple-900 to-indigo-900">
    <h1 class="text-4xl font-bold text-center">V300 Film Platform</h1>
  </header>

  <main class="container mx-auto p-6">
    <h2 class="text-2xl mb-6">Popular Movies</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6">
      {movies.map(movie => (
        <MovieCard movie={movie} />
      ))}
    </div>
  </main>
</MainLayout>
