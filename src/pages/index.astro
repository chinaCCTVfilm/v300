---
import MainLayout from '../layouts/MainLayout.astro';

const apiUrl = 'https://v300-tmdb-worker.limingvv789.workers.dev/api/popular';

let result = '加载中...';
let isError = false;

try {
  const res = await fetch(apiUrl);
  const text = await res.text();
  result = res.ok ? text : `错误 ${res.status}: ${text}`;
  isError = !res.ok;
} catch (err) {
  result = `网络错误: ${err}`;
  isError = true;
}
---

<MainLayout title="V300 调试页面">
  <header class="p-6 bg-gradient-to-r from-purple-900 to-indigo-900">
    <h1 class="text-4xl font-bold text-center">V300 Worker 测试</h1>
  </header>

  <main class="container mx-auto p-6">
    <h2 class="text-2xl mb-6">Worker 返回结果</h2>
    <pre class="bg-gray-800 p-6 text-sm overflow-auto whitespace-pre-wrap {isError ? 'text-red-400' : 'text-green-400'}">
{result}
    </pre>
  </main>
</MainLayout>